{
  "info": {
    "name": "Student Hub — Full Payment Flow",
    "description": "Complete flow: Register → Login → Property → Booking → Payment",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",       "value": "http://localhost:8000/api", "type": "string" },
    { "key": "student_token",  "value": "", "type": "string" },
    { "key": "landlord_token", "value": "", "type": "string" },
    { "key": "property_id",    "value": "", "type": "string" },
    { "key": "booking_id",     "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "1️⃣  Register",
      "item": [
        {
          "name": "Register as Student",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"test_student\",\n    \"email\": \"student@test.com\",\n    \"password\": \"TestPass123\",\n    \"role\": \"student\",\n    \"first_name\": \"Ahmed\",\n    \"last_name\": \"Mohamed\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register/",
              "host": ["{{base_url}}"],
              "path": ["auth", "register", ""]
            }
          }
        },
        {
          "name": "Register as Landlord",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"test_landlord\",\n    \"email\": \"landlord@test.com\",\n    \"password\": \"TestPass123\",\n    \"role\": \"landlord\",\n    \"first_name\": \"Omar\",\n    \"last_name\": \"Hassan\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register/",
              "host": ["{{base_url}}"],
              "path": ["auth", "register", ""]
            }
          }
        }
      ]
    },
    {
      "name": "2️⃣  Login",
      "item": [
        {
          "name": "Login as Student",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access) {",
                  "    pm.collectionVariables.set('student_token', json.access);",
                  "    console.log('✅ Student token saved');",
                  "} else {",
                  "    console.log('❌ Login failed: ' + JSON.stringify(json));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"test_student\",\n    \"password\": \"TestPass123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login/",
              "host": ["{{base_url}}"],
              "path": ["auth", "login", ""]
            }
          }
        },
        {
          "name": "Login as Landlord",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access) {",
                  "    pm.collectionVariables.set('landlord_token', json.access);",
                  "    console.log('✅ Landlord token saved');",
                  "} else {",
                  "    console.log('❌ Login failed: ' + JSON.stringify(json));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"test_landlord\",\n    \"password\": \"TestPass123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login/",
              "host": ["{{base_url}}"],
              "path": ["auth", "login", ""]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"refresh\": \"paste_refresh_token_here\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/token/refresh/",
              "host": ["{{base_url}}"],
              "path": ["auth", "token", "refresh", ""]
            }
          }
        },
        {
          "name": "My Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{student_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/profile/",
              "host": ["{{base_url}}"],
              "path": ["auth", "profile", ""]
            }
          }
        }
      ]
    },
    {
      "name": "3️⃣  Property",
      "item": [
        {
          "name": "Create Property (landlord)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) {",
                  "    pm.collectionVariables.set('property_id', json.id);",
                  "    console.log('✅ Property ID saved: ' + json.id);",
                  "} else {",
                  "    console.log('❌ Failed: ' + JSON.stringify(json));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{landlord_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Test Apartment Cairo\",\n    \"price\": \"1000.00\",\n    \"city\": \"Cairo\",\n    \"property_type\": \"apartment\",\n    \"gender_preference\": \"male\",\n    \"num_rooms\": 2,\n    \"num_beds\": 2,\n    \"num_bathrooms\": 1,\n    \"min_stay_months\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/properties/create/",
              "host": ["{{base_url}}"],
              "path": ["properties", "create", ""]
            }
          }
        },
        {
          "name": "List Properties",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{student_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/properties/",
              "host": ["{{base_url}}"],
              "path": ["properties", ""]
            }
          }
        },
        {
          "name": "Property Detail",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{student_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/properties/{{property_id}}/",
              "host": ["{{base_url}}"],
              "path": ["properties", "{{property_id}}", ""]
            }
          }
        },
        {
          "name": "My Properties (landlord)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{landlord_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/properties/landlord/properties/",
              "host": ["{{base_url}}"],
              "path": ["properties", "landlord", "properties", ""]
            }
          }
        }
      ]
    },
    {
      "name": "4️⃣  Booking",
      "item": [
        {
          "name": "Create Booking (student)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) {",
                  "    pm.collectionVariables.set('booking_id', json.id);",
                  "    console.log('✅ Booking ID saved: ' + json.id);",
                  "    console.log('Status: ' + json.status);",
                  "    console.log('Total (cents): ' + json.total_amount_cents);",
                  "    console.log('Deposit (cents): ' + json.deposit_amount_cents);",
                  "    console.log('Remaining (cents): ' + json.remaining_amount_cents);",
                  "    console.log('Expires at: ' + json.expires_at);",
                  "} else {",
                  "    console.log('❌ Failed: ' + JSON.stringify(json));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{student_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"property\": {{property_id}},\n    \"move_in_date\": \"2025-09-01\",\n    \"duration_months\": 3,\n    \"message\": \"Test booking for payment flow\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/bookings/",
              "host": ["{{base_url}}"],
              "path": ["bookings", ""]
            },
            "description": "booking_id auto-saved. Check console for deposit and total amounts."
          }
        },
        {
          "name": "My Bookings",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{student_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/bookings/my/",
              "host": ["{{base_url}}"],
              "path": ["bookings", "my", ""]
            }
          }
        },
        {
          "name": "Confirm Booking (landlord)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{landlord_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"status\": \"confirmed\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/bookings/{{booking_id}}/status/",
              "host": ["{{base_url}}"],
              "path": ["bookings", "{{booking_id}}", "status", ""]
            },
            "description": "Only works after booking status = deposit_paid (webhook must have fired first)."
          }
        },
        {
          "name": "Cancel Booking (student)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{student_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"status\": \"cancelled\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/bookings/{{booking_id}}/status/",
              "host": ["{{base_url}}"],
              "path": ["bookings", "{{booking_id}}", "status", ""]
            }
          }
        }
      ]
    },
    {
      "name": "5️⃣  Payments",
      "item": [
        {
          "name": "① Initiate Deposit",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.iframe_url) {",
                  "    console.log('✅ Payment initiated!');",
                  "    console.log('👉 Open this URL in your browser:');",
                  "    console.log(json.iframe_url);",
                  "    console.log('Order ID: ' + json.order_id);",
                  "} else {",
                  "    console.log('❌ Failed: ' + JSON.stringify(json));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{student_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"booking_id\": {{booking_id}},\n    \"phone\": \"01012345678\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/payments/deposit/",
              "host": ["{{base_url}}"],
              "path": ["payments", "deposit", ""]
            },
            "description": "Copy iframe_url from Postman console → open in browser → pay.\n\nTest card:\nNumber : 4987654321098769\nExpiry : 05/25\nCVV    : 100\nName   : Test Account"
          }
        },
        {
          "name": "② My Payments (check status)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{student_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/payments/my/",
              "host": ["{{base_url}}"],
              "path": ["payments", "my", ""]
            },
            "description": "Before paying → status: pending\nAfter paying in iframe → status: completed"
          }
        },
        {
          "name": "③ Pay Remaining Online",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.iframe_url) {",
                  "    console.log('✅ Remaining payment initiated!');",
                  "    console.log('👉 Open this URL in your browser:');",
                  "    console.log(json.iframe_url);",
                  "} else {",
                  "    console.log('❌ Failed: ' + JSON.stringify(json));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{student_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"booking_id\": {{booking_id}},\n    \"phone\": \"01012345678\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/payments/remaining/online/",
              "host": ["{{base_url}}"],
              "path": ["payments", "remaining", "online", ""]
            },
            "description": "Only works after booking status = confirmed."
          }
        },
        {
          "name": "④ Mark Remaining as Cash (landlord)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{landlord_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"booking_id\": {{booking_id}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/payments/remaining/offline/",
              "host": ["{{base_url}}"],
              "path": ["payments", "remaining", "offline", ""]
            },
            "description": "Landlord records cash payment → booking becomes completed."
          }
        }
      ]
    }
  ]
}